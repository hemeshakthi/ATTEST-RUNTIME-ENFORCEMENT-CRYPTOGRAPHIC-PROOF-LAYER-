{
  "name": "nitrostack-app",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "prisma generate",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "dev:api": "tsx watch src/dashboard-api/server.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\" \"cd frontend && npm run dev\"",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nitrostack/core": "1.0.0",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "concurrently": "^9.2.4",
    "prisma": "^5.22.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
